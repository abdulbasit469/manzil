# Backend (copy to .env in this folder — same directory as package.json)
PORT=5000
# Listen on all interfaces (default in code is 0.0.0.0). Set HOST=127.0.0.1 to block LAN.
# HOST=0.0.0.0

# MongoDB — required. Get connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/manzil?retryWrites=true&w=majority

# Optional: comma-separated extra frontend origins for CORS (LAN is auto-allowed when NODE_ENV !== production)
# FRONTEND_URLS=http://192.168.1.10:3000

# Frontend (manzil tajarba/frontend/.env.local) — only if defaults are wrong
# Vite uses same hostname as the browser + port 5000 for API by default.
# VITE_API_BASE_URL=http://192.168.1.10:5000
# VITE_API_PORT=5000

# Groq OR xAI for chatbot + comparisons (Groq key = gsk_…, xAI = xai-…)
# GROQ_API_KEY=
# XAI_API_KEY=

# Gmail API for OTP (HTTPS; good on Railway). See backend/env.template for OAuth steps.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GMAIL_FROM_EMAIL=
# GOOGLE_OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground
