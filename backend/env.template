# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/manzil?retryWrites=true&w=majority
# Optional alternate name (server uses MONGODB_URI first, then MONGO_URI)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/manzil?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
# Generate a random secret key for production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# --- LLM for chatbot + comparisons (Groq OR xAI) ---
# Groq — https://console.groq.com (keys start with gsk_)
GROQ_API_KEY=your_groq_key
# Optional: GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL_LIST=llama-3.3-70b-versatile,llama-3.1-8b-instant
# GROQ_API_BASE=https://api.groq.com/openai/v1
# Free/on-demand Groq: keep requests small (TPM limits). Defaults: max output 4096, input ~9k/11k chars.
# GROQ_JSON_MAX_TOKENS=4096
# GROQ_PROGRAM_INPUT_CHARS=9000
# GROQ_UNIVERSITY_INPUT_CHARS=11000

# xAI Grok — https://console.x.ai (keys start with xai-)
XAI_API_KEY=your_xai_api_key
# GROK_MODEL / GROK_MODEL_LIST — xAI model fallbacks (see grokClient.js)
# XAI_API_BASE=https://api.x.ai/v1
# GROK_JSON_MAX_TOKENS=32000
# GROK_CHAT_MAX_TOKENS=8192

# --- Email: OTP and password reset ---
# Preferred on Railway: Gmail API over HTTPS (no SMTP). You need a one-time OAuth refresh token.
# In Google Cloud Console: enable Gmail API; OAuth client (Web): add Authorized redirect URI:
#   https://developers.google.com/oauthplayground
# Open OAuth Playground → settings → use your client id/secret → Gmail API v1 → .../auth/gmail.send
# After authorize, exchange for tokens and copy the refresh token below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Address that sends mail (must match the Google account you authorized)
GMAIL_FROM_EMAIL=youraccount@gmail.com
# Must match the redirect URI used when the refresh token was created (Playground default below).
# GOOGLE_OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# Legacy fallback: Gmail SMTP with app password (often blocked on some hosts)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
